DirectoryIndex index.php
<IfModule mod_rewrite.c>
RewriteEngine On

# Keep existing files/directories working directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route legacy flat PHP URLs to organized folders internally (no URL change).
RewriteRule ^([A-Za-z0-9_-]+\.php)$ legacy_router.php?file=$1 [L,QSA,NC]
</IfModule>
