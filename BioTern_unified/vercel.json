{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "@vercel/php"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "uploads/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "documents/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*\\.php)$",
      "dest": "/legacy_router.php?file=$1"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.php"
    }
  ]
}
