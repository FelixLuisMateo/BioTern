{
  "version": 2,
  "builds": [
    {
      "src": "auth/building.png",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "uploads/**",
      "use": "@vercel/static"
    },
    {
      "src": "index.php",
      "use": "vercel-php"
    },
    {
      "src": "legacy_router.php",
      "use": "vercel-php"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "^/BioTern/BioTern_unified/(.*)$",
      "dest": "/$1"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/uploads/(.*)$",
      "dest": "/uploads/$1"
    },
    {
      "src": "^/(.*\\.(?:css|js|map|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot))$",
      "dest": "/$1"
    },
    {
      "src": "^/api/(.*\\.php)$",
      "dest": "/legacy_router.php?file=$1"
    },
    {
      "src": "^/([A-Za-z0-9_-]+)/?$",
      "dest": "/legacy_router.php?slug=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*\\.php)$",
      "dest": "/legacy_router.php?file=$1"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.php"
    }
  ]
}
