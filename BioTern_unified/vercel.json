{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "vercel-php"
    },
    {
      "src": "legacy_router.php",
      "use": "vercel-php"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*\\.php)$",
      "dest": "/legacy_router.php?file=$1"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.php"
    }
  ]
}
