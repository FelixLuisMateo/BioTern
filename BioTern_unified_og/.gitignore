# Environment
.env
.env.*
!.env.example

# Dependencies
vendor/
node_modules/

# Build/cache/runtime
/public/build/
/public/hot
/storage/*.key
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/
/bootstrap/cache/*.php

# User-generated files
uploads/*
!uploads/.gitkeep

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Composer / NPM lock strategy
# Keep composer.lock tracked for app consistency
# package-lock.json can be tracked if Node tooling is used consistently

# Temporary / backups
*.tmp
*.temp
*.bak
*.swp
*.orig
