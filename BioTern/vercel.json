{
  "version": 2,
  "builds": [
    {
      "src": "auth/building.png",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "uploads/**",
      "use": "@vercel/static"
    },
    {
      "src": "index.php",
      "use": "vercel-php"
    },
    {
      "src": "legacy_router.php",
      "use": "vercel-php"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "^/BioTern/BioTern/(.*)$",
      "dest": "/$1"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/uploads/(.*)$",
      "dest": "/uploads/$1"
    },
    {
      "src": "^/(.*\\.(?:css|js|map|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot))$",
      "dest": "/$1"
    },
    {
      "src": "^/api/([^/]+\\.php)$",
      "dest": "/legacy_router.php?file=$1"
    },
    {
      "src": "^/f20h_ingest\\.php$",
      "dest": "/legacy_router.php?file=f20h_ingest.php"
    },
    {
      "src": "^/bridge_profile\\.php$",
      "dest": "/legacy_router.php?file=bridge_profile.php"
    },
    {
      "src": "^/bridge_health\\.php$",
      "dest": "/legacy_router.php?file=bridge_health.php"
    },
    {
      "src": "^/bridge_commands_claim\\.php$",
      "dest": "/legacy_router.php?file=bridge_commands_claim.php"
    },
    {
      "src": "^/bridge_commands_complete\\.php$",
      "dest": "/legacy_router.php?file=bridge_commands_complete.php"
    },
    {
      "src": "^/includes/avatar-image\\.php$",
      "dest": "/legacy_router.php?file=avatar-image.php"
    },
    {
      "src": "^/attendance(?:\\.php)?$",
      "dest": "/legacy_router.php?file=attendance.php"
    },
    {
      "src": "^/external-attendance(?:\\.php)?$",
      "dest": "/legacy_router.php?file=external-attendance.php"
    },
    {
      "src": "^/external-attendance-manual(?:\\.php)?$",
      "dest": "/legacy_router.php?file=external-attendance-manual.php"
    },
    {
      "src": "^/student-internal-dtr(?:\\.php)?$",
      "dest": "/legacy_router.php?file=student-internal-dtr.php"
    },
    {
      "src": "^/student-dtr(?:\\.php)?$",
      "dest": "/legacy_router.php?file=student-dtr.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*\\.php)$",
      "dest": "/legacy_router.php?file=$1"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.php"
    }
  ]
}
