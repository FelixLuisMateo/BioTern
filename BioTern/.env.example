# Copy this file to .env.local on your localhost machine when you want
# localhost and the online deployment to use the same database.
BIOTERN_DB_TARGET=railway
BIOTERN_REQUIRE_REMOTE_DB=1

# Prefer the public Railway/MySQL URL, not mysql.railway.internal.
MYSQL_PUBLIC_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# Alternative host-style config:
# MYSQL_PUBLIC_HOST=HOST
# MYSQL_PUBLIC_PORT=PORT
# MYSQL_PUBLIC_USER=USER
# MYSQL_PUBLIC_PASSWORD=PASSWORD
# MYSQL_PUBLIC_DATABASE=DATABASE
